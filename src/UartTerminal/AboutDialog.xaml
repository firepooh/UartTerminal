<Window x:Class="UartTerminal.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UartTerminal 정보"
        Icon="/UartTerminal.ico"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="22,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0" Source="/UartTerminal.ico" Width="56" Height="56"
               VerticalAlignment="Top" Margin="0,2,18,0" RenderOptions.BitmapScalingMode="HighQuality"/>

        <StackPanel Grid.Column="1">
            <TextBlock Text="UartTerminal" FontSize="21" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock x:Name="VersionText" Margin="0,3,0,0"
                       FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                       Foreground="{StaticResource TextMuted}"/>

            <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12.5" LineHeight="18"
                       Foreground="{StaticResource TextDim}"
                       Text="ESP-IDF/ESP32 개발용 시리얼 터미널 — 컬러 로그, 창 크기에 맞춘 reflow, 화면 분할, USB 자동 재연결, AI(MCP) 포트 공유."/>

            <TextBlock x:Name="RuntimeText" Margin="0,12,0,0" FontSize="11.5"
                       Foreground="{StaticResource TextFaint}"/>
            <TextBlock Margin="0,3,0,0" FontSize="11.5">
                <Hyperlink x:Name="RepoLink" Click="Repo_Click"
                           Foreground="{StaticResource Blue}" TextDecorations="{x:Null}">github.com/firepooh/UartTerminal</Hyperlink>
            </TextBlock>

            <Button x:Name="OkButton" Content="확인" Width="90" Height="30"
                    Margin="0,20,0,0" HorizontalAlignment="Right"
                    IsDefault="True" IsCancel="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
