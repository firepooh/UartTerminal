<UserControl x:Class="UartTerminal.UartDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <DockPanel>
        <!-- 하단 입력 전용 창(3라인). 터미널 출력이 쏟아질 때 안정적으로 명령을 입력.
             클릭해서 포커스를 주면 여기로 입력, Enter 로 전송. 기본 포커스는 메인 터미널(type-through). -->
        <Border x:Name="InputBorder" DockPanel.Dock="Bottom"
                BorderBrush="#3E3E42" BorderThickness="1" Margin="4,2,4,4" Background="#252526">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" x:Name="InputLabel" Text="입력창"
                           Foreground="#888888" Margin="6,0,8,0" VerticalAlignment="Center"/>
                <TextBox x:Name="InputBox"
                         Height="60" AcceptsReturn="False" TextWrapping="Wrap"
                         Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                         BorderThickness="0" Padding="0,2"
                         FontFamily="Consolas" FontSize="13"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         GotKeyboardFocus="InputBox_GotFocus"
                         LostKeyboardFocus="InputBox_LostFocus"
                         PreviewKeyDown="InputBox_PreviewKeyDown"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="ViewHost" Grid.Column="0" Background="#1E1E1E"/>
            <ScrollBar x:Name="VScroll" Grid.Column="1" Orientation="Vertical"
                       Minimum="0" Maximum="0" SmallChange="1" Scroll="VScroll_Scroll"/>
        </Grid>
    </DockPanel>
</UserControl>
