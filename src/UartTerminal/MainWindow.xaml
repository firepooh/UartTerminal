<Window x:Class="UartTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UartTerminal" Height="560" Width="960"
        Icon="/UartTerminal.ico"
        Background="#1E1E1E"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="터미널(_T)">
                <MenuItem x:Name="MenuReconnect" Header="재연결(_R)" InputGestureText="Alt+N" Click="Reconnect_Click"/>
                <MenuItem x:Name="MenuDisconnect" Header="연결 해제(_D)" InputGestureText="Alt+I" Click="Disconnect_Click"/>
                <Separator/>
                <MenuItem Header="종료(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="편집(_E)">
                <MenuItem Header="복사" InputGestureText="Ctrl+Ins" Click="Copy_Click"/>
                <MenuItem Header="붙여넣기" InputGestureText="Shift+Ins / 우클릭" Click="Paste_Click"/>
                <Separator/>
                <MenuItem Header="화면 지우기" Click="ClearScreen_Click"/>
                <MenuItem Header="버퍼 지우기" Click="ClearBuffer_Click"/>
                <Separator/>
                <MenuItem Header="맨 아래로" InputGestureText="Ctrl+End" Click="ScrollEnd_Click"/>
            </MenuItem>
            <MenuItem Header="보기(_V)">
                <MenuItem Header="폰트 크게" InputGestureText="Ctrl++" Click="FontLarger_Click"/>
                <MenuItem Header="폰트 작게" InputGestureText="Ctrl+-" Click="FontSmaller_Click"/>
            </MenuItem>
            <MenuItem Header="MCP(_M)">
                <MenuItem x:Name="MenuMcpEnabled" Header="MCP 서버 활성화" IsCheckable="True"
                          Click="McpEnabled_Click"/>
                <MenuItem x:Name="MenuMcpReadOnly" Header="AI 읽기 전용 (TX·제어선 차단)" IsCheckable="True"
                          Click="McpReadOnly_Click"/>
                <Separator/>
                <MenuItem Header="등록 명령 복사 (claude mcp add)" Click="McpCopyCmd_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#2D2D30" Foreground="#CCCCCC">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="시작 중…"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="McpStatusText" Text="MCP: 꺼짐" Foreground="#888888"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="MetricsText" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <!-- 하단 입력 전용 창(3라인). 터미널 출력이 쏟아질 때 안정적으로 명령을 입력.
             클릭해서 포커스를 주면 여기로 입력, Enter 로 전송. 기본 포커스는 메인 터미널(type-through). -->
        <Border x:Name="InputBorder" DockPanel.Dock="Bottom"
                BorderBrush="#3E3E42" BorderThickness="1" Margin="4,2,4,4" Background="#252526">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" x:Name="InputLabel" Text="입력창"
                           Foreground="#888888" Margin="6,0,8,0" VerticalAlignment="Center"/>
                <TextBox x:Name="InputBox"
                         Height="60" AcceptsReturn="False" TextWrapping="Wrap"
                         Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                         BorderThickness="0" Padding="0,2"
                         FontFamily="Consolas" FontSize="13"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         GotKeyboardFocus="InputBox_GotFocus"
                         LostKeyboardFocus="InputBox_LostFocus"
                         PreviewKeyDown="InputBox_PreviewKeyDown"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="ViewHost" Grid.Column="0" Background="#1E1E1E"/>
            <ScrollBar x:Name="VScroll" Grid.Column="1" Orientation="Vertical"
                       Minimum="0" Maximum="0" SmallChange="1" Scroll="VScroll_Scroll"/>
        </Grid>
    </DockPanel>
</Window>
