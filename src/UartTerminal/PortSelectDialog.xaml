<Window x:Class="UartTerminal.PortSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="포트 선택 — UartTerminal"
        Icon="/UartTerminal.ico"
        Width="460" Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8"
                   Text="연결할 시리얼 포트를 선택하세요:" FontSize="13"/>

        <ListBox x:Name="PortList" Grid.Row="1"
                 MouseDoubleClick="PortList_MouseDoubleClick"
                 DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="2" Margin="0,8,0,8" Foreground="#666"
                   Text="설정(고정): 115200 bps · 8 · None · 1 · Flow None · DTR/RTS 해제(보드 리셋 안 함)"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RefreshButton" Content="새로고침" Width="80" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button x:Name="OkButton" Content="연결" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="취소" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
