<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         UartTerminal - Dark Theme (GitHub-dark). 사용자 제공 디자인 시안을 적용.
         원본 시안의 XAML 오류(</Setter> 누락, </Style> 중복)를 교정함.
         ============================================================ -->

    <!-- ===== Color palette ===== -->
    <Color x:Key="C.Bg">#FF0D1117</Color>
    <Color x:Key="C.BgDeep">#FF0A0D12</Color>
    <Color x:Key="C.BgPanel">#FF0B0F16</Color>
    <Color x:Key="C.Surface">#FF11161F</Color>
    <Color x:Key="C.SurfaceHover">#FF1A2130</Color>
    <Color x:Key="C.Border">#FF1C2433</Color>
    <Color x:Key="C.BorderStrong">#FF263141</Color>
    <Color x:Key="C.TabIdle">#FF0F141D</Color>
    <Color x:Key="C.Text">#FFE6EDF5</Color>
    <Color x:Key="C.TextDim">#FFA9B4C4</Color>
    <Color x:Key="C.TextMuted">#FF8B97A8</Color>
    <Color x:Key="C.TextFaint">#FF5B6675</Color>
    <Color x:Key="C.Accent">#FF2F81F7</Color>
    <Color x:Key="C.AccentDeep">#FF1F6FEB</Color>
    <Color x:Key="C.Green">#FF2EA043</Color>
    <Color x:Key="C.GreenBright">#FF3FB950</Color>
    <Color x:Key="C.Blue">#FF58A6FF</Color>
    <Color x:Key="C.Amber">#FFD29922</Color>
    <Color x:Key="C.Red">#FFF85149</Color>
    <Color x:Key="C.Purple">#FFBC8CFF</Color>
    <Color x:Key="C.State">#FFF0883E</Color>
    <Color x:Key="C.Idle">#FF4B5563</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="Bg"            Color="{StaticResource C.Bg}"/>
    <SolidColorBrush x:Key="BgDeep"        Color="{StaticResource C.BgDeep}"/>
    <SolidColorBrush x:Key="BgPanel"       Color="{StaticResource C.BgPanel}"/>
    <SolidColorBrush x:Key="Surface"       Color="{StaticResource C.Surface}"/>
    <SolidColorBrush x:Key="SurfaceHover"  Color="{StaticResource C.SurfaceHover}"/>
    <SolidColorBrush x:Key="BorderBrush2"  Color="{StaticResource C.Border}"/>
    <SolidColorBrush x:Key="BorderStrong"  Color="{StaticResource C.BorderStrong}"/>
    <SolidColorBrush x:Key="TabIdle"       Color="{StaticResource C.TabIdle}"/>
    <SolidColorBrush x:Key="Text"          Color="{StaticResource C.Text}"/>
    <SolidColorBrush x:Key="TextDim"       Color="{StaticResource C.TextDim}"/>
    <SolidColorBrush x:Key="TextMuted"     Color="{StaticResource C.TextMuted}"/>
    <SolidColorBrush x:Key="TextFaint"     Color="{StaticResource C.TextFaint}"/>
    <SolidColorBrush x:Key="Accent"        Color="{StaticResource C.Accent}"/>
    <SolidColorBrush x:Key="Green"         Color="{StaticResource C.Green}"/>
    <SolidColorBrush x:Key="GreenBright"   Color="{StaticResource C.GreenBright}"/>
    <SolidColorBrush x:Key="Blue"          Color="{StaticResource C.Blue}"/>
    <SolidColorBrush x:Key="Amber"         Color="{StaticResource C.Amber}"/>
    <SolidColorBrush x:Key="Red"           Color="{StaticResource C.Red}"/>
    <SolidColorBrush x:Key="Purple"        Color="{StaticResource C.Purple}"/>
    <SolidColorBrush x:Key="StateBrush"    Color="{StaticResource C.State}"/>
    <SolidColorBrush x:Key="Idle"          Color="{StaticResource C.Idle}"/>

    <!-- ===== Fonts ===== -->
    <FontFamily x:Key="MonoFont">Cascadia Code, Cascadia Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI, Malgun Gothic</FontFamily>

    <!-- ============================================================
         INPUT ROW (command entry) — 필드형 TextBox
         ============================================================ -->
    <Style x:Key="CommandInput" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Green}"/>
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary "Send" button -->
    <Style x:Key="SendButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{StaticResource C.Accent}" Offset="0"/>
                                <GradientStop Color="{StaticResource C.AccentDeep}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary chip button -->
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="8"
                            Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource BorderStrong}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3A4656"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         STATUS BAR
         ============================================================ -->
    <Style x:Key="StatusBarPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="30"/>
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusDivider" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Fill" Value="{StaticResource BorderStrong}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
