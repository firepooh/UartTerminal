<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         UartTerminal - Dark Theme (GitHub-dark). 사용자 제공 디자인 시안을 적용.
         원본 시안의 XAML 오류(</Setter> 누락, </Style> 중복)를 교정함.
         ============================================================ -->

    <!-- ===== Color palette ===== -->
    <Color x:Key="C.Bg">#FF0D1117</Color>
    <Color x:Key="C.BgDeep">#FF0A0D12</Color>
    <Color x:Key="C.BgPanel">#FF0B0F16</Color>
    <Color x:Key="C.Surface">#FF11161F</Color>
    <Color x:Key="C.SurfaceHover">#FF1A2130</Color>
    <Color x:Key="C.Border">#FF1C2433</Color>
    <Color x:Key="C.BorderStrong">#FF263141</Color>
    <Color x:Key="C.TabIdle">#FF0F141D</Color>
    <Color x:Key="C.Text">#FFE6EDF5</Color>
    <Color x:Key="C.TextDim">#FFA9B4C4</Color>
    <Color x:Key="C.TextMuted">#FF8B97A8</Color>
    <Color x:Key="C.TextFaint">#FF5B6675</Color>
    <Color x:Key="C.Accent">#FF2F81F7</Color>
    <Color x:Key="C.AccentDeep">#FF1F6FEB</Color>
    <Color x:Key="C.Green">#FF2EA043</Color>
    <Color x:Key="C.GreenBright">#FF3FB950</Color>
    <Color x:Key="C.Blue">#FF58A6FF</Color>
    <Color x:Key="C.Amber">#FFD29922</Color>
    <Color x:Key="C.Red">#FFF85149</Color>
    <Color x:Key="C.Purple">#FFBC8CFF</Color>
    <Color x:Key="C.State">#FFF0883E</Color>
    <Color x:Key="C.Idle">#FF4B5563</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="Bg"            Color="{StaticResource C.Bg}"/>
    <SolidColorBrush x:Key="BgDeep"        Color="{StaticResource C.BgDeep}"/>
    <SolidColorBrush x:Key="BgPanel"       Color="{StaticResource C.BgPanel}"/>
    <SolidColorBrush x:Key="Surface"       Color="{StaticResource C.Surface}"/>
    <SolidColorBrush x:Key="SurfaceHover"  Color="{StaticResource C.SurfaceHover}"/>
    <SolidColorBrush x:Key="BorderBrush2"  Color="{StaticResource C.Border}"/>
    <SolidColorBrush x:Key="BorderStrong"  Color="{StaticResource C.BorderStrong}"/>
    <SolidColorBrush x:Key="TabIdle"       Color="{StaticResource C.TabIdle}"/>
    <SolidColorBrush x:Key="Text"          Color="{StaticResource C.Text}"/>
    <SolidColorBrush x:Key="TextDim"       Color="{StaticResource C.TextDim}"/>
    <SolidColorBrush x:Key="TextMuted"     Color="{StaticResource C.TextMuted}"/>
    <SolidColorBrush x:Key="TextFaint"     Color="{StaticResource C.TextFaint}"/>
    <SolidColorBrush x:Key="Accent"        Color="{StaticResource C.Accent}"/>
    <SolidColorBrush x:Key="AccentDeep"    Color="{StaticResource C.AccentDeep}"/>
    <SolidColorBrush x:Key="Green"         Color="{StaticResource C.Green}"/>
    <SolidColorBrush x:Key="GreenBright"   Color="{StaticResource C.GreenBright}"/>
    <SolidColorBrush x:Key="Blue"          Color="{StaticResource C.Blue}"/>
    <SolidColorBrush x:Key="Amber"         Color="{StaticResource C.Amber}"/>
    <SolidColorBrush x:Key="Red"           Color="{StaticResource C.Red}"/>
    <SolidColorBrush x:Key="Purple"        Color="{StaticResource C.Purple}"/>
    <SolidColorBrush x:Key="StateBrush"    Color="{StaticResource C.State}"/>
    <SolidColorBrush x:Key="Idle"          Color="{StaticResource C.Idle}"/>

    <!-- ===== Fonts ===== -->
    <FontFamily x:Key="MonoFont">Cascadia Code, Cascadia Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI, Malgun Gothic</FontFamily>

    <!-- ============================================================
         INPUT ROW (command entry) — 필드형 TextBox
         ============================================================ -->
    <Style x:Key="CommandInput" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Green}"/>
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary "Send" button -->
    <Style x:Key="SendButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{StaticResource C.Accent}" Offset="0"/>
                                <GradientStop Color="{StaticResource C.AccentDeep}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary chip button -->
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="8"
                            Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource BorderStrong}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3A4656"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         STATUS BAR
         ============================================================ -->
    <Style x:Key="StatusBarPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Height" Value="30"/>
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusDivider" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Fill" Value="{StaticResource BorderStrong}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ============================================================
         MENU (dark) — 기본 WPF 메뉴는 밝은 팝업/시스템색이라 다크에서 비활성처럼 보임.
         전체를 다크로 스타일링하고 항목이 명확히 활성으로 보이게 함.
         ============================================================ -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource Bg}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
    </Style>

    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1" Margin="30,4,6,4" Fill="{StaticResource BorderStrong}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Check" Grid.Column="0" Text="&#x2713;" FontSize="11"
                                       Foreground="{StaticResource GreenBright}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Margin="8,0,0,0" Visibility="Collapsed"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" Margin="8,5,12,5"/>
                            <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Path x:Name="Arrow" Grid.Column="3" Data="M0,0 L4,4 L0,8 Z"
                                  Fill="{StaticResource TextMuted}" VerticalAlignment="Center"
                                  Margin="0,0,8,0" Visibility="Collapsed"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" PopupAnimation="Fade">
                                <Border Background="{StaticResource Surface}"
                                        BorderBrush="{StaticResource BorderStrong}" BorderThickness="1"
                                        CornerRadius="6" Padding="3" Margin="0,2,10,10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FF000000" BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         화면 분할 아이콘 (16x16 외곽선 지오메트리) — 사용자 제공 디자인(SplitIcons).
         Path 에 Stroke 로 그린다(채우기 아님). 어느 DPI 에서도 선명.
         ============================================================ -->
    <RectangleGeometry x:Key="Ic.Single" Rect="2.5,3.5,11,9" RadiusX="1.5" RadiusY="1.5"/>

    <GeometryGroup x:Key="Ic.SplitV">
        <RectangleGeometry Rect="2.5,3.5,11,9" RadiusX="1.5" RadiusY="1.5"/>
        <LineGeometry StartPoint="8,3.5" EndPoint="8,12.5"/>
    </GeometryGroup>

    <GeometryGroup x:Key="Ic.SplitH">
        <RectangleGeometry Rect="2.5,3.5,11,9" RadiusX="1.5" RadiusY="1.5"/>
        <LineGeometry StartPoint="2.5,8" EndPoint="13.5,8"/>
    </GeometryGroup>

    <GeometryGroup x:Key="Ic.Grid">
        <RectangleGeometry Rect="2.5,3.5,11,9" RadiusX="1.5" RadiusY="1.5"/>
        <LineGeometry StartPoint="8,3.5" EndPoint="8,12.5"/>
        <LineGeometry StartPoint="2.5,8" EndPoint="13.5,8"/>
    </GeometryGroup>

    <!-- 분할 툴바용 ToggleButton: 활성 시 accent 채움. 아이콘 지오메트리는 Tag 로 전달. -->
    <Style x:Key="SplitToggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" CornerRadius="5" Background="Transparent">
                        <Path x:Name="Ic" Data="{TemplateBinding Tag}"
                              Stroke="{TemplateBinding Foreground}" StrokeThickness="1.4"
                              Stretch="None" Width="16" Height="16"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDeep}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 세그먼트 알약 컨테이너(분할 토글 그룹을 감싼다) -->
    <Style x:Key="SplitToolbar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TabIdle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="3"/>
    </Style>

    <!-- ============================================================
         SCROLLBAR (GitHub-dark) — 트랙/썸/화살표. 암시적 스타일로 앱 전체 통일.
         ============================================================ -->
    <SolidColorBrush x:Key="ScrollThumb"      Color="#FF363C46"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#FF4B5563"/>

    <Geometry x:Key="Geo.ArrowUp">M0,5 L4,1 L8,5 Z</Geometry>
    <Geometry x:Key="Geo.ArrowDown">M0,1 L4,5 L8,1 Z</Geometry>
    <Geometry x:Key="Geo.ArrowLeft">M5,0 L1,4 L5,8 Z</Geometry>
    <Geometry x:Key="Geo.ArrowRight">M1,0 L5,4 L1,8 Z</Geometry>

    <!-- 썸(가운데 막대) -->
    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="tb" Background="{StaticResource ScrollThumb}" CornerRadius="4" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tb" Property="Background" Value="{StaticResource ScrollThumbHover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="tb" Property="Background" Value="{StaticResource ScrollThumbHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 트랙 빈 공간(페이지 이동) — 투명 -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 위/아래(좌/우) 화살표 버튼 -->
    <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="3">
                        <Path x:Name="ar" Width="8" Height="6" Stretch="Uniform"
                              Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                              Fill="{StaticResource TextFaint}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                            <Setter TargetName="ar" Property="Fill" Value="{StaticResource TextDim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="{StaticResource BgDeep}"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="MinWidth" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                        </Grid.RowDefinitions>
                        <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}"
                                      Command="ScrollBar.LineUpCommand" Content="{StaticResource Geo.ArrowUp}"/>
                        <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                        <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}"
                                      Command="ScrollBar.LineDownCommand" Content="{StaticResource Geo.ArrowDown}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Grid.Column="0" Style="{StaticResource ScrollBarLineButton}"
                                              Command="ScrollBar.LineLeftCommand" Content="{StaticResource Geo.ArrowLeft}"/>
                                <Track x:Name="PART_Track" Grid.Column="1">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                                <RepeatButton Grid.Column="2" Style="{StaticResource ScrollBarLineButton}"
                                              Command="ScrollBar.LineRightCommand" Content="{StaticResource Geo.ArrowRight}"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
