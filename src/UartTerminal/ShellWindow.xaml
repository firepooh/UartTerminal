<Window x:Class="UartTerminal.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UartTerminal" Height="620" Width="1020"
        Icon="/UartTerminal.ico"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- 탭 닫기(×) 버튼 -->
        <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cb" Background="Transparent" CornerRadius="4">
                            <TextBlock Text="&#x2715;" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cb" Property="Background" Value="{StaticResource Red}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COM 포트 탭 헤더(둥근 상단, GitHub-dark) -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Margin="0,3,4,-1" Padding="11,7"
                                CornerRadius="8,8,0,0"
                                Background="{StaticResource TabIdle}"
                                BorderBrush="{StaticResource BorderBrush2}"
                                BorderThickness="1,1,1,0">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Bg}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 탭 스트립(헤더 전용; 콘텐츠는 아래 ContentHost) -->
        <Style TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="Transparent" BorderThickness="0" Padding="8,5,8,0">
                            <TabPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Padding="6,2" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush2}">
            <MenuItem Header="터미널(_T)">
                <MenuItem Header="새 연결(탭 추가)" InputGestureText="Ctrl+T" Click="NewTab_Click"/>
                <MenuItem Header="재연결" InputGestureText="Alt+N" Click="Reconnect_Click"/>
                <MenuItem Header="연결 해제" InputGestureText="Alt+I" Click="Disconnect_Click"/>
                <MenuItem x:Name="MenuAutoReconnect" Header="자동 재연결 (USB 재접속 시)"
                          IsCheckable="True" Click="AutoReconnect_Click"/>
                <Separator/>
                <MenuItem Header="새 창으로 분리" Click="Detach_Click"/>
                <MenuItem Header="메인 창으로 합치기" Click="Merge_Click"/>
                <MenuItem Header="탭 닫기" InputGestureText="Ctrl+W" Click="CloseTab_Click"/>
                <Separator/>
                <MenuItem Header="종료" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="편집(_E)">
                <MenuItem Header="복사" InputGestureText="Ctrl+Ins" Click="Copy_Click"/>
                <MenuItem Header="붙여넣기" InputGestureText="Shift+Ins / 우클릭" Click="Paste_Click"/>
                <Separator/>
                <MenuItem Header="화면 지우기" Click="ClearScreen_Click"/>
                <MenuItem Header="버퍼 지우기" Click="ClearBuffer_Click"/>
                <Separator/>
                <MenuItem Header="맨 아래로" InputGestureText="Ctrl+End" Click="ScrollEnd_Click"/>
            </MenuItem>
            <MenuItem Header="보기(_V)">
                <MenuItem Header="폰트 크게" InputGestureText="Ctrl++" Click="FontLarger_Click"/>
                <MenuItem Header="폰트 작게" InputGestureText="Ctrl+-" Click="FontSmaller_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuSplitSingle" Header="단일 화면" IsCheckable="True" Click="SplitSingle_Click"/>
                <MenuItem x:Name="MenuSplitV" Header="좌우 분할" IsCheckable="True" Click="SplitV_Click"/>
                <MenuItem x:Name="MenuSplitH" Header="상하 분할" IsCheckable="True" Click="SplitH_Click"/>
                <MenuItem x:Name="MenuSplitGrid" Header="격자 분할" IsCheckable="True" Click="SplitGrid_Click"/>
            </MenuItem>
            <MenuItem Header="MCP(_M)">
                <MenuItem x:Name="MenuMcpEnabled" Header="MCP 서버 활성화" IsCheckable="True"
                          Click="McpEnabled_Click"/>
                <MenuItem x:Name="MenuMcpReadOnly" Header="AI 읽기 전용 (TX·제어선 차단)" IsCheckable="True"
                          Click="McpReadOnly_Click"/>
                <Separator/>
                <MenuItem Header="등록 명령 복사 (claude mcp add)" Click="McpCopyCmd_Click"/>
            </MenuItem>
            <MenuItem Header="도움말(_H)">
                <MenuItem Header="UartTerminal 정보(_A)" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- 세그먼트 상태바 -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource StatusBarPanel}">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnDot" Width="7" Height="7" Fill="{StaticResource Idle}" Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource StatusText}"
                               Foreground="{StaticResource Text}" Text="시작 중…"/>
                    <Rectangle Style="{StaticResource StatusDivider}" Margin="14,0"/>
                    <TextBlock x:Name="McpStatusText" Style="{StaticResource StatusText}" Text="MCP: 꺼짐"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="MetricsText" Style="{StaticResource StatusText}" Text=""/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 탭 스트립 + 화면 분할 아이콘 툴바(오른쪽 알약) -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TabControl x:Name="Tabs" Grid.Column="0" BorderThickness="0"
                            SelectionChanged="Tabs_SelectionChanged"/>
                <Border Grid.Column="1" Style="{StaticResource SplitToolbar}"
                        VerticalAlignment="Center" Margin="6,4,10,6">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="BtnSplitSingle" Style="{StaticResource SplitToggle}"
                                      Tag="{StaticResource Ic.Single}" Click="SplitSingle_Click" ToolTip="단일 화면"/>
                        <ToggleButton x:Name="BtnSplitV" Style="{StaticResource SplitToggle}"
                                      Tag="{StaticResource Ic.SplitV}" Click="SplitV_Click" ToolTip="좌우 분할"/>
                        <ToggleButton x:Name="BtnSplitH" Style="{StaticResource SplitToggle}"
                                      Tag="{StaticResource Ic.SplitH}" Click="SplitH_Click" ToolTip="상하 분할"/>
                        <ToggleButton x:Name="BtnSplitGrid" Style="{StaticResource SplitToggle}"
                                      Tag="{StaticResource Ic.Grid}" Click="SplitGrid_Click" ToolTip="격자 분할"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 실제 문서(터미널) 렌더 영역: 탭 모드=활성 1개, 분할 모드=격자 배치 -->
        <Grid x:Name="ContentHost" Background="{StaticResource Bg}"/>
    </DockPanel>
</Window>
